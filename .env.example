# ============================================================
# AI Dungeon Master - Environment Variables Example
# Copy this file to .env and fill in your actual values.
# Never commit your .env file to version control.
# ============================================================

# ------------------------------------------------------------
# Google Gemini API (required for AI functionality)
# Get your free API key at: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use (default: gemini-2.0-flash)
# Options: gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash, gemini-pro
GEMINI_MODEL=gemini-2.0-flash

# ------------------------------------------------------------
# Backend Server Configuration (backend/ directory)
# ------------------------------------------------------------
DEBUG=True
HOST=0.0.0.0
PORT=5000

# CORS allowed origins (comma-separated list)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
